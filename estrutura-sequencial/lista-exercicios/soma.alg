Algoritmo "soma"
// Curso de Algoritmos e Lógica de Programação
// Professor: Nelio Alves
// Estrutura Sequencial
// Lista de Exercícios
// Github: @pythanx
Var
   x, y, soma: inteiro

Inicio
   escreval("Digite o valor de X: ")
   leia(x)
   escreval("Digite o valor de Y: ")
   leia(y)
   
   soma <- x + y
   
   escreval("SOMA = ", soma)

Fimalgoritmo
