Algoritmo "circulo"
// Curso de Algoritmos e Lógica de Programação
// Professor: Nelio Alves
// Estrutura Sequencial
// Lista de Exercícios
// Github: @pythanx
Var
  r, area: real
  

Inicio
   escreval("Digite o valor do raio do cícrulo: ")
   leia(r)
   
   area <- Pi * (Exp(r,2))
   
   escreval("AREA = ", area:8:3)

Fimalgoritmo
